{
  "expo": {
    "name": "Namastey",
    "slug": "namastey",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "namastey",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.namastey.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FF6B35"
      },
      "package": "com.namastey.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Namastey needs access to your photos to update your profile picture."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "apiUrl": "http://172.27.151.48:5001/api/v1"
    }
  }
}
